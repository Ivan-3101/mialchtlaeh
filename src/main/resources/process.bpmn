        "keyName": "agentId",
        "dataType": "string",
        "path": "$.agentId"
      },
      {
        "keyName": "success",
        "dataType": "string",
        "path": "$.success"
      }
    ]
  },
  "consolidatedReport": {
    "storeIn": "objectStorage",
    "storageType": "minio",
    "mergeVariables": true,
    "targetPath": "1/HealthClaim/${TicketID}/consolidated/report.json",
    "targetVarName": "consolidatedReportMinioPath",
    "mergePaths": [
      {
        "keyName": "policy_holder",
        "sourceType": "processVariable",
        "variableName": "policy_holder"
      },
      {
        "keyName": "currentDocAnswer",
        "sourceType": "responseJson",
        "dataType": "json",
        "path": "$.rawResponse.answer"
      },
      {
        "keyName": "vpaAttribs",
        "sourceType": "processVariable",
        "variableName": "vpaAttribs"
      },
      {
        "keyName": "accountAttribs",
        "sourceType": "processVariable",
        "variableName": "accountAttribs"
      },
      {
        "keyName": "doc1FullResult",
        "sourceType": "minioFile",
        "sourcePath": "1/HealthClaim/${TicketID}/Identify_Forged_Documents/Doc1.pdf.json",
        "dataType": "json",
        "path": "$"
      },
      {
        "keyName": "doc1Answer",
        "sourceType": "minioFile",
        "sourcePath": "1/HealthClaim/${TicketID}/Identify_Forged_Documents/Doc1.pdf.json",
        "dataType": "json",
