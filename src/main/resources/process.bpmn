  },
  "isForgedAsJSON": {
    "storeIn": "processVariable",
    "dataType": "json",
    "path": "$.rawResponse.answer"
  },
  "entireForgeryResponse": {
    "storeIn": "processVariable",
    "dataType": "json",
    "path": "$"
  },
  "forgeryArchiveFile": {
    "storeIn": "objectStorage",
    "storageType": "minio",
    "dataType": "json",
    "path": "$.rawResponse",
    "targetPath": "1/HealthClaim/${TicketID}/forgery_specific_json_extracted_using_minio_extract/${attachment}_archive.json",
    "targetVarName": "forgeryArchiveMinioPath"
  },
  "forgerySummary": {
    "storeIn": "processVariable",
    "dataType": "json",
    "mergeVariables": true,
    "mergePaths": [
      {
        "keyName": "agentId",
        "dataType": "string",
        "path": "$.agentId"
      },
      {
        "keyName": "callSuccess",
        "dataType": "string",
        "path": "$.success"
      }
    ]
  },
  "forgeryMergedArchive": {
    "storeIn": "objectStorage",
    "storageType": "minio",
    "mergeVariables": true,
    "targetPath": "1/HealthClaim/${TicketID}/forgery_merged_archive/${attachment}_merged.json",
